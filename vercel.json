{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "domains": [
    "fgc.fastjobcareer.com",
    "fast-global-visa-counsultant.vercel.app"
  ]
}
